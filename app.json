{
  "expo": {
    "name": "vivid",
    "slug": "vivid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/vivid-logo-round.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/vivid-logo-round.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vivid.app",
      "associatedDomains": [
        "applinks:vivid.app"
      ],
      "icon": "./assets/vivid-logo-round.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/vivid-logo-round.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.vivid.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "vivid",
              "host": "*.vivid.app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "vivid",
    "deepLinking": {
      "enabled": true
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-router",
      "expo-dev-client"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1b26719c-9081-452f-b906-667e5f91a92b"
      }
    },
    "owner": "techboy1999"
  }
}
